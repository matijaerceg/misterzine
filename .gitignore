# Regenerable data
data/repos/
data/snapshots/
data/cache/*
# ...but keep the screenshot manifest: export-web's image re-tag needs it, and
# the daily CI job has no other way to recover it (the PNGs it maps are committed
# under docs/images/, but this manifest is what ties them to each row + its dims).
!data/cache/image_manifest.json
__pycache__/
*.pyc

# Keep the db and exports? They're regenerable but useful to commit for history.
# Uncomment to ignore:
# data/misterzine.sqlite
# data/exports/

# Claude Code local state
.claude/
